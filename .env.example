# ==========================================================
# Shelter - Environment Variables
# Copy this file to ".env" and fill in your own values.
# Never commit your real ".env" file to version control.
# ==========================================================

# Port the server will run on (Render sets this automatically in
# production, so this is mainly used for local development)
PORT=3000

# Admin login username (you choose this)
ADMIN_USERNAME=admin

# Admin login password - DO NOT put a plain password here.
# Generate a secure hash by running:
#   npm run hash -- "YourPasswordHere"
# Then paste the resulting hash below.
ADMIN_PASSWORD_HASH=$2a$10$.vwasRZ2H0aSMz1b.TFUguP4d9pzbJ4EufUzUZhQA1yzKAzEWdnfa

# A long random string used to sign session cookies.
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=please_change_this_to_a_long_random_string

# ----------------------------------------------------------
# MongoDB Atlas - stores all house listing data permanently.
# Free account: https://www.mongodb.com/cloud/atlas/register
# Get this from: Database -> Connect -> Drivers -> copy the
# connection string, then replace <db_password> with your
# database user's real password.
# ----------------------------------------------------------
MONGODB_URI=mongodb+srv://Wizzy:HgP5sbZ5xJwEaZF4@cluster0.a3oqsbl.mongodb.net/shelter?appName=Cluster0

# ----------------------------------------------------------
# Cloudinary - stores all uploaded house photos permanently.
